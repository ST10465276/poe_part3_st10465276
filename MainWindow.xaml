<Window x:Class="part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:part2"
        mc:Ignorable="d"
        Title="CyberBot" 
        Height="450" 
        Width="800"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid>
        <!--start of parent grid-->
        <Image
        Source="/image1.jpg"
        Stretch="UniformToFill"
        StretchDirection="Both"/>

        <Grid
            x:Name="logo_grid"
            Visibility="Visible">
            <!--start of logo grid-->

            <!--displaying the logo image-->
            <Image  
                Source="/logo.png"
                Height="200"
                Width="250"
                Margin="0,0,0,150"
                
                />
            <!--Displaying a message-->
            <TextBlock  
                Height="50"
                Width="400"
                Margin="0,150,0,0"
                Text="Welcome to CyberBot, Click start to proceed"
                FontFamily="Rockwell"
                FontSize="19"
                />
            <!--Creating a start button-->
            <Button 
               Height="50"
               Width="150"
               Margin="0,240,0,0"
               Content="Start CyberBot"
               FontFamily="Rockwell"
               Click="start_click"
               Background="LightBlue"
               Foreground="DarkBlue"
               BorderBrush="SteelBlue"
               BorderThickness="2"
             >
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

        </Grid>
        <!--end of logo grid-->

        <Grid
            x:Name="username_grid"
            Visibility="Hidden"
            >
            <!--start of asking for username grid-->

            <!--displaying the logo-->
            <Image  
                Source="/logo.png"
                Height="100"
                Width="150"
                Margin="0,0,0,250"
                />

            <!--displaying the welcoming message-->
            <TextBlock  
                Height="60"
                Width="350"
                Margin="0,0,0,50"
                FontSize="17"
                FontFamily="Rockwell"
                TextAlignment="Center"               
                >
                
                Welcome to CyberBot
                <LineBreak />
                I'm here to assist you with you online safety
            </TextBlock
                >

            <!--labeling the textbox-->
            <TextBlock
                Height="50"
                Width="250"
                Margin="0,80,90,0"
                Text="Enter Username"
                Foreground="DeepPink"
                TextAlignment="Justify"
                FontSize="15"
                />

            <!--TextBox-->
            <Border 
               Margin="100,130,90,0"
               CornerRadius="3"
               BorderBrush="#4A90E2"
               BorderThickness="1"
               Background="White"
               Height="50"
               Width="350"
              >
                <TextBox  
                 x:Name="user_input"
               
                />
            </Border>

            <!--textblock for error message-->
            <TextBlock
                x:Name="error_username"
                Height="50"
                Width="250"
                Margin="0,250,90,0"
                Foreground="DarkRed"
                Text="Username required!"
                TextAlignment="Justify"
                FontSize="15"
                />

            <!--Button for submiting the name-->
            <Button  
                Height="50"
                Width="350"
                Margin="100,300,90,0"
                Content="submit username"
                Click="submit_username"
                Background="LightBlue"
                Foreground="DarkBlue"
                BorderBrush="SteelBlue"
                BorderThickness="1"
                >

                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>


            </Button>
        </Grid>
        <!--end of asking username grid-->


        <Grid 
            x:Name="options_grid"
            Visibility="Hidden"
            >
            <!--start of options grid -->


            <Image 
                
                Source="logo.png" 
                Width="105" 
                Height="115"
                HorizontalAlignment="Center" 
                 VerticalAlignment="Top"
                 Margin="0,2,670,0"/>
            <Image 
                
                Source="logo.png" 
                Width="105" 
                Height="115"
                HorizontalAlignment="Center" 
                VerticalAlignment="Top"
                Margin="670,2,0,0"/>

            <!-- Title -->
            <TextBlock
              Text="CyberBot" 
FontSize="22" 
FontWeight="Bold" 
Foreground="#2C3E50"
HorizontalAlignment="Center"
        Height="50"
        Width="200"
        TextAlignment="Center"
   Margin="0,0,0,360"
                
                />
            <!-- Welcome Message -->
            <TextBlock 
               Text="Welcome !" 
               FontSize="11" 
               Foreground="#7F8C8D"
               x:Name="welcoming_users"
               HorizontalAlignment="Center"
                Height="50"
               Margin="0,0,0,260"/>






            <!-- options Label -->
            <TextBlock 
              Text="OPTIONS" 
              FontSize="15" 
              FontWeight="Bold" 
              Foreground="#2C3E50"
               FontFamily="Rockwell"
               HorizontalAlignment="Left"
               Margin="110,110,0,0"/>




            <!-- Row 1 -->


            <!-- Chat -->
            <Border Width="240" 
            Height="130"
            Background="White" 
            CornerRadius="6"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            Cursor="Hand"
            MouseLeftButtonDown="chat_card_click"
            Margin="110,135,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
                <Grid>
                    <Image Source="/chats_icon.png" 
                   Width="35" 
                   Height="35"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Top"
                   Margin="0,12,0,0"/>

                    <TextBlock Text="Chats" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,-8,0,0"/>

                    <TextBlock Text="Start or continue chat and add tasks" 
                       FontSize="9"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,30"/>

                    <Border Background="#3498DB" 
                    Height="28"
                    CornerRadius="0,0,6,6"
                    VerticalAlignment="Bottom">
                        <TextBlock Text="OPEN CHAT" 
                           Foreground="White" 
                           FontSize="8"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>



            <!--  View Tasks -->
            <Border 
                
                Width="240" 
            Height="130"
            Background="White" 
            CornerRadius="6"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            Cursor="Hand"
            MouseLeftButtonDown="view_tasks_card_click"
            Margin="445,135,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
                <Grid>
                    <Image Source="/tasks.jpg" 
                   Width="35" 
                   Height="35"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Top"
                   Margin="0,12,0,0"/>

                    <TextBlock Text="View Tasks" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,-8,0,0"/>

                    <TextBlock Text="View all your tasks, delete and mark done." 
                       FontSize="9"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,30"/>

                    <Border Background="#2196F3" 
                    Height="28"
                    CornerRadius="0,0,6,6"
                    VerticalAlignment="Bottom">
                        <TextBlock Text="VIEW TASKS" 
                           Foreground="White" 
                           FontSize="8"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Row 2 -->

            <!--View Logs -->
            <Border 
            Width="240" 
            Height="130"
            Background="White" 
            CornerRadius="6"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            Cursor="Hand"
            MouseLeftButtonDown="view_logs_card_click"
            Margin="110,275,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
                <Grid>
                    <Image Source="/logs.jpg" 
                   Width="35" 
                   Height="35"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Top"
                   Margin="0,12,0,0"/>

                    <TextBlock Text="View Logs" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,-8,0,0"/>

                    <TextBlock Text="Track activity history" 
                       FontSize="9"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,30"/>

                    <Border Background="#FF9800" 
                    Height="28"
                    CornerRadius="0,0,6,6"
                    VerticalAlignment="Bottom">
                        <TextBlock Text="VIEW LOGS" 
                           Foreground="White" 
                           FontSize="8"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Quiz -->
            <Border
            Width="240" 
            Height="130"
            Background="White" 
            CornerRadius="6"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            Cursor="Hand"
            MouseLeftButtonDown="quiz_card_click"
            Margin="450,275,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
                <Grid>
                    <Image Source="/quiz.png" 
                   Width="35" 
                   Height="35"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Top"
                   Margin="0,12,0,0"/>

                    <TextBlock Text="Quiz" 
                       FontWeight="Bold" 
                       FontSize="13"
                       Foreground="#333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,-8,0,0"/>

                    <TextBlock Text="Test your knowledge, about cyber-security" 
                       FontSize="9"
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,30"/>

                    <Border Background="#9C27B0" 
                    Height="28"
                    CornerRadius="0,0,6,6"
                    VerticalAlignment="Bottom">
                        <TextBlock Text="START QUIZ" 
                           Foreground="White" 
                           FontSize="8"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

        </Grid>
        <!--end of options grid -->


        <Grid
            x:Name="chat_grid"
            Visibility="Hidden"
            >
            <!--start of chatting grid-->

            <!-- back button -->
            <Button  
         Height="40"
         Width="30"
         Margin="0,0,750,350"
         Content="Back"
         Click="back_main"
         Background="LightBlue"
         Foreground="DarkBlue"
         BorderBrush="SteelBlue"
         BorderThickness="1"
        >
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>


            <!--using a listview for chatting-->
            <ListView  
                x:Name="chats_view"
                Height="300"
                Width="700"
                Margin="0,0,0,90"
                Background="LightBlue"
                BorderBrush="Transparent"
                HorizontalContentAlignment="Stretch"
                Focusable="False"
              />

            <!--Textbox for user entering question-->
            <Border 
                Margin="0,300,250,0"
                CornerRadius="3"
                BorderBrush="#4A90E2"
                BorderThickness="1"
                Background="White"
                Height="50"
                Width="450"
              >
                <TextBox  
                   x:Name="enter_question"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="20,0,20,0"
                   FontSize="14"
                   FontFamily="Segoe UI"
                   VerticalContentAlignment="Center"
                   Foreground="#333333"
                 />
            </Border>

            <!--sending a question button-->

            <Button  
               Height="50"
               Width="210"
               Margin="480,300,0,0"
               Content="send question"
               Click="send_question"
               Background="LightBlue"
               Foreground="DarkBlue"
               BorderBrush="SteelBlue"
               BorderThickness="1"
              >
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

        </Grid>
        <!--end of chatting grid-->





        <!--start of task grid-->
        <Grid x:Name="tasks_grid" Visibility="Hidden">

            <Image 
        Source="logo.png" 
        Width="105" 
        Height="115"
        HorizontalAlignment="Center" 
        VerticalAlignment="Top"
        Margin="670,2,0,0"/>

            <!-- Back Button -->
            <Button  
        Height="40"
        Width="38"
        Margin="10,15,0,0"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Content="Back"
        Click="back_main"
        Background="LightBlue"
        Foreground="DarkBlue"
        BorderBrush="SteelBlue"
        BorderThickness="1">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- Title -->
            <TextBlock 
        Text="CyberBot Task Management"
        FontSize="20"
        FontWeight="SemiBold"
        Foreground="#2C3E50"
        HorizontalAlignment="Center"
        Margin="0,15,0,0"/>

            <!-- Pending Button -->
            <Button  
        x:Name="pending_btn"
        Height="38"
        Width="130"
        Margin="270,60,0,0"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Content="PENDING"
        Click="show_pending_tasks"
        Background="#FF9800"
        Foreground="White"
        BorderBrush="#FB8C00"
        BorderThickness="1"
        FontWeight="Bold"
        FontSize="13">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- Completed Button -->
            <Button  
        x:Name="completed_btn"
        Height="38"
        Width="130"
        Margin="450,60,0,0"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Content="COMPLETED"
        Click="show_completed_tasks"
        Background="#4CAF50"
        Foreground="White"
        BorderBrush="#45a049"
        BorderThickness="1"
        FontWeight="Bold"
        FontSize="13">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- ListView for Tasks -->
            <Grid Margin="0,107,0,3">
                <ScrollViewer 
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            BorderBrush="#E0E0E0"
            BorderThickness="1">

                    <ListView  
                x:Name="tasks"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                HorizontalContentAlignment="Stretch"
                Focusable="False"
                FontSize="13">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="TASK NAME" Width="150" DisplayMemberBinding="{Binding task_name}"/>
                                <GridViewColumn Header="DESCRIPTION" Width="200" DisplayMemberBinding="{Binding task_description}"/>
                                <GridViewColumn Header="DUE DATE" Width="120" DisplayMemberBinding="{Binding task_reminder}"/>
                                <GridViewColumn Header="STATUS" Width="90" DisplayMemberBinding="{Binding task_status}"/>
                                <GridViewColumn Header="ACTION" Width="260">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                                                <Button 
                                            Content="Mark Complete" 
                                            Click="mark_task_complete"
                                            Background="#2196F3"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Height="28"
                                            Width="115"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Margin="0,0,8,0"
                                            Cursor="Hand">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="5"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                                <Button 
                                            Content="Delete" 
                                            Click="delete_task"
                                            Background="#DC3545"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Height="28"
                                            Width="85"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Cursor="Hand">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="5"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </ScrollViewer>
            </Grid>

            <Image 
        Source="/logo.png" 
        Width="105" 
        Height="115"
        HorizontalAlignment="Left" 
        VerticalAlignment="Top"
        Margin="53,1,0,0"/>

        </Grid>
        <!--end of task grid-->




        <!--start of quiz grid-->
        <Grid x:Name="quiz_grid"
      Visibility="Hidden"
      >


            <Image 
       
       Source="/logo.png" 
       Width="105" 
       Height="65"
       HorizontalAlignment="Left" 
       VerticalAlignment="Top"
       Margin="72,3,0,0"/>







            <!-- Back Button -->
            <Button Content="Back"
            Width="50"
            Height="35"
            Margin="15,12,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="back_main"
    Background="LightBlue"
    Foreground="DarkBlue"
    BorderBrush="SteelBlue"
    BorderThickness="1"/>





            <!-- Header -->
            <Border Height="60"
            VerticalAlignment="Top">







                <TextBlock Text="CYBERBOT QUIZ"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>







            </Border>



            <!-- Question Number -->
            <TextBlock x:Name="question_number"
               Text="Question 1 / 10"
               FontSize="13"
               FontWeight="Bold"
               Foreground="#475569"
               Margin="25,75,0,0"/>

            <!-- Score -->
            <TextBlock x:Name="score_text"
       Text="Score: 0"
       FontSize="13"
       FontWeight="Bold"
       Foreground="#16A34A"
       HorizontalAlignment="Right"
       Margin="0,75,25,0"/>
            <TextBlock x:Name="score_last"
 Text=""
 FontSize="13"
 FontWeight="Bold"
 Foreground="#ff22"
 HorizontalAlignment="Right"
 Margin="0,76,86,-1"/>
            <TextBlock 
                x:Name="scored"
 Text=""
 FontSize="13"
 FontWeight="Bold"
 Foreground="#ff22"
 HorizontalAlignment="Right"
 Margin="0,75,96,0"/>


            <!-- Question Card -->
            <Border Margin="25,100,25,0"
            Height="80"
            Background="White"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            CornerRadius="12"
            VerticalAlignment="Top">

                <TextBlock x:Name="question_text"
                   Text="Question appears here..."
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#1E293B"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="20"/>
            </Border>

            <!-- ANSWER 1 -->
            <Button x:Name="answer1"
            Content="Answer 1"
            Width="360"
            Height="70"
            Margin="25,205,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="answer_clicked"
            Background="White"
            BorderBrush="#3B82F6"
            BorderThickness="2"
            FontSize="14"
            FontWeight="SemiBold"/>

            <!-- ANSWER 2 -->
            <Button x:Name="answer2"
            Content="Answer 2"
            Width="360"
            Height="70"
            Margin="415,205,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="answer_clicked"
            Background="White"
            BorderBrush="#3B82F6"
            BorderThickness="2"
            FontSize="14"
            FontWeight="SemiBold"/>

            <!-- ANSWER 3 -->
            <Button x:Name="answer3"
            Content="Answer 3"
            Width="360"
            Height="70"
            Margin="25,290,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="answer_clicked"
            Background="White"
            BorderBrush="#3B82F6"
            BorderThickness="2"
            FontSize="14"
            FontWeight="SemiBold"/>

            <!-- ANSWER 4 -->
            <Button x:Name="answer4"
            Content="Answer 4"
            Width="360"
            Height="70"
            Margin="415,290,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Click="answer_clicked"
            Background="White"
            BorderBrush="#3B82F6"
            BorderThickness="2"
            FontSize="14"
            FontWeight="SemiBold"/>

            <!-- Result -->
            <TextBlock 
                x:Name="result_text"
           FontSize="15"
                Text=""
           FontWeight="Bold"
           HorizontalAlignment="Center"
           Margin="0,345,0,0"
           Visibility="Visible"/>

            <Button x:Name="next_btn"
        Content="NEXT QUESTION"
        Width="180"
        Height="40"
        Margin="0,370,0,0"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Click="next_question"
        Background="#16A34A"
        Foreground="White"
        BorderThickness="0"
        FontWeight="Bold"
        Visibility="Collapsed"/>
            <Image 
       
                Source="/logo.png" 
                Width="105" 
                Height="65"
                HorizontalAlignment="Left" 
                VerticalAlignment="Top"
                Margin="698,2,0,0"/>

        </Grid>
        <!--end of quiz grid-->

        <!-- Activities Log Grid -->
        <Grid 
            x:Name="activities_grid"
              Visibility="Hidden">

            <Image 
   Source="logo.png" 
   Width="106" 
   Height="62"
   HorizontalAlignment="Left" 
   VerticalAlignment="Top"
   Margin="688,4,0,0"/>

            <!-- Back Button -->
            <Button  
   Height="40"
   Width="38"
   Margin="10,15,0,0"
   HorizontalAlignment="Left"
   VerticalAlignment="Top"
   Content="Back"
   Click="back_main"
   Background="LightBlue"
   Foreground="DarkBlue"
   BorderBrush="SteelBlue"
   BorderThickness="1">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- Title -->
            <TextBlock 
Text="CyberBot Activity Log"
FontSize="20"
FontWeight="SemiBold"
Foreground="#2C3E50"
HorizontalAlignment="Center"
Margin="0,15,0,0"/>
            <TextBlock 
Text="Track all your activities withing the CyberBot app"

Foreground="#2C3E50"
HorizontalAlignment="Center"
Margin="0,52,0,-37"/>





            <!--using a listview for chatting-->
            <ListView  
                x:Name="logs_view"
                Width="700"
                Margin="50,83,50,4"
                Background="LightBlue"
                BorderBrush="Transparent"
                HorizontalContentAlignment="Stretch"
                Focusable="False"
              />
            <Image 
                Source="/logo.png" 
                Width="106" 
                Height="62"
                HorizontalAlignment="Left" 
                VerticalAlignment="Top"
                Margin="66,4,0,0"/>




        </Grid>



    </Grid>
    <!--end of parent grid-->
</Window>
